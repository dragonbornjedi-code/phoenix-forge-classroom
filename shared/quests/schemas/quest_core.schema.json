{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://phoenixforge.local/schemas/quest_core.schema.json",
  "title": "QuestCore",
  "description": "Layer 1 — reusable activity core without narrative skin.",
  "type": "object",
  "required": ["id", "realm", "subcategory", "title", "steps", "deep_objectives"],
  "properties": {
    "id": { "type": "string" },
    "realm": { "type": "string" },
    "subcategory": { "type": "string" },
    "title": { "type": "string" },
    "category_display": { "type": "string" },
    "difficulty": { "type": "integer", "minimum": 1, "maximum": 5 },
    "xp": { "type": "integer", "minimum": 0 },
    "duration_minutes": { "type": "integer", "minimum": 1 },
    "materials": { "type": "array", "items": { "type": "string" } },
    "deep_objectives": {
      "type": "object",
      "required": ["executive_function", "social_emotional", "sensory", "academic"],
      "properties": {
        "executive_function": { "type": "string" },
        "social_emotional": { "type": "string" },
        "sensory": { "type": "string" },
        "academic": { "type": "string" }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["instruction"],
        "properties": {
          "instruction": { "type": "string" },
          "timer": { "type": "integer" },
          "sensory_load": { "type": "integer", "minimum": 1, "maximum": 5 },
          "ef_demand": { "type": "integer", "minimum": 1, "maximum": 5 },
          "minigame_id": { "type": "string" },
          "voice_category": { "type": "string" },
          "voice_clip": { "type": "string" }
        }
      }
    },
    "scaffolding": { "type": "string" },
    "extension": { "type": "string" },
    "parent_notes": { "type": "string" },
    "real_world_connection": { "type": "string" }
  },
  "additionalProperties": false
}
